<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Alarm and reliability permissions -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- camera -->
    <uses-permission android:name="android.permission.CAMERA"/>


    <!-- Audio control permissions -->
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY" />

    <!-- Bluetooth detection for audio routing override -->
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <!-- Step counter for wake task -->
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />

    <!-- Battery optimization detection -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Disable battery optimizations for critical alarms -->
    <uses-permission android:name="android.permission.REQUEST_SCHEDULE_EXACT_ALARM" />
    <uses-feature android:name="android.hardware.camera.any"/>
    <application
        android:name=".AlarmApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ReliableAlarm"
        android:requestLegacyExternalStorage="false"
        tools:targetApi="31">
        <activity
            android:name=".ui.preview.TaskPreviewActivity"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:exported="false"
            android:showWhenLocked="true"
            android:turnScreenOn="true"/>

        <!-- Main Entry Point -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Alarm List -->
        <activity
            android:name=".ui.AlarmListActivity"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:exported="false"
            android:launchMode="singleTop"
            android:parentActivityName=".ui.MainActivity" />

        <!-- Alarm Edit/Create -->
        <activity
            android:name=".ui.AlarmEditActivity"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".ui.AlarmListActivity" />

        <!-- ========== WAKE TASK CONFIG ACTIVITIES - ADD THESE ========== -->

        <!-- Math Challenge Config -->
        <activity
            android:name=".ui.config.MathConfigActivity"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".ui.AlarmEditActivity" />

        <!-- Step Challenge Config -->
        <activity
            android:name=".ui.config.StepConfigActivity"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".ui.AlarmEditActivity" />

        <!-- Shake Challenge Config -->
        <activity
            android:name=".ui.config.ShakeConfigActivity"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".ui.AlarmEditActivity" />

        <!-- QR Code Challenge Config -->
        <activity

            android:name=".ui.config.QrConfigActivity"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".ui.AlarmEditActivity" />
        <!-- Tap Task Config -->
        <activity

            android:name=".ui.config.TapTaskConfigActivity"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".ui.AlarmEditActivity" />
        <!-- Typing Task Config -->
        <activity

            android:name=".ui.config.TypingConfigActivity"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".ui.AlarmEditActivity" />
        <!-- Colors Balls Task Config -->
        <activity

            android:name=".ui.config.ColorBallsConfigActivity"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".ui.AlarmEditActivity" />
        <!-- ========== END WAKE TASK CONFIG ACTIVITIES ========== -->

        <!-- Reliability Options -->
        <activity
            android:name=".ui.ReliabilityOptionsActivity"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:exported="false"
            android:parentActivityName=".ui.MainActivity" />

        <!-- Wake Task Options -->
        <activity
            android:name=".ui.WakeTaskOptionsActivity"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:exported="false"
            android:parentActivityName=".ui.MainActivity" />

        <!-- Streak History -->
        <activity
            android:name=".ui.StreakHistoryActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:parentActivityName=".ui.MainActivity" />

        <!-- Alarm Trigger Activity - Full Screen, Turn Screen On -->
        <activity
            android:name=".ui.AlarmTriggerActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:launchMode="singleInstance"
            android:excludeFromRecents="true"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:taskAffinity=""
            android:configChanges="orientation|screenSize|keyboardHidden" />

        <!-- Foreground Service for Alarm Playback -->
        <service
            android:name=".reliability.AlarmService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <!-- Boot Receiver - Re-register all alarms after reboot -->
        <receiver
            android:name=".reliability.BootReceiver"
            android:enabled="true"
            android:exported="true"
            android:directBootAware="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- Alarm Receiver - Primary trigger mechanism -->
        <receiver
            android:name=".reliability.AlarmReceiver"
            android:enabled="true"
            android:exported="false" />

        <!-- WakeConfirmationReceiver for notification actions -->
        <receiver
            android:name=".system.WakeConfirmationReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="com.reliablealarm.app.WAKE_YES" />
                <action android:name="com.reliablealarm.app.WAKE_NO" />
            </intent-filter>
        </receiver>

        <!-- WorkManager for backup alarm triggering -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup" />
        </provider>

    </application>

</manifest>