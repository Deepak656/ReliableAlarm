<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ══ BRAND PRIMARY — Electric Orange ════════════════════
         The single accent. Use sparingly — only for the most
         important action or number on each screen.          -->
    <color name="accent_orange">#FF5C00</color>
    <color name="accent_orange_light">#FFF0E8</color>
    <color name="accent_orange_dark">#CC4900</color>

    <!-- ══ BACKGROUNDS ════════════════════════════════════════
         Warm off-white background stops the app looking
         clinical. surface_dark is for hero cards only.      -->
    <color name="background_main">#F5F3EF</color>
    <color name="surface_card">#FFFFFF</color>
    <color name="surface_dark">#1C1C1E</color>
    <color name="surface_elevated">#EFEDE9</color>
    <color name="card_stroke">#EEECE8</color>

    <!-- ══ SEMANTIC COLORS ════════════════════════════════════ -->
    <color name="success_green">#00C48C</color>
    <color name="success_green_light">#E6FAF5</color>

    <color name="danger_red">#FF3B30</color>
    <color name="danger_red_light">#FFF0EF</color>

    <color name="streak_fire">#FF5C00</color>
    <color name="streak_gold">#FFB800</color>
    <color name="streak_gold_light">#FFF8E0</color>

    <!-- ══ TEXT ════════════════════════════════════════════════
         Never use pure black on white — always text_primary.
         text_inverse* are for use on surface_dark cards.    -->
    <color name="text_primary">#1C1C1E</color>
    <color name="text_secondary">#48484A</color>
    <color name="text_tertiary">#8E8E93</color>
    <color name="text_inverse">#FFFFFF</color>
    <color name="text_inverse_soft">#EBEBF5</color>

    <!-- ══ MATERIAL THEME MAPPING ══════════════════════════════
         Keeps Material components working without the default
         purple. Maps to orange-based theme.                 -->
    <color name="md_theme_primary">#FF5C00</color>
    <color name="md_theme_primary_dark">#CC4900</color>
    <color name="md_theme_primary_light">#FFF0E8</color>
    <color name="md_theme_secondary">#00C48C</color>
    <color name="md_theme_secondary_dark">#009970</color>

    <!-- ══ LEGACY — do not use in new screens ══════════════════
         Kept only for backward compatibility with old code.
         Migrate away from these as each screen is redesigned. -->
    <color name="neutral_gray">#EEECE8</color>
    <color name="neutral_gray_light">#F5F3EF</color>
    <color name="miss_red">#FF3B30</color>
    <color name="alarm_background">#1C1C1E</color>
    <color name="black">#FF000000</color>
    <color name="white">#FFFFFFFF</color>
    <color name="purple_200">#FFBB86FC</color>
    <color name="purple_700">#FF3700B3</color>
    <color name="teal_200">#FF03DAC5</color>

</resources>