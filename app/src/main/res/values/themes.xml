<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base Application Theme -->
    <style name="Theme.ReliableAlarm" parent="Theme.MaterialComponents.Light.DarkActionBar">
        <item name="colorPrimary">@color/md_theme_primary</item>
        <item name="colorPrimaryVariant">@color/md_theme_primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/md_theme_secondary</item>
        <item name="colorSecondaryVariant">@color/md_theme_secondary_dark</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/background_main</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:windowBackground">@color/background_main</item>

        <!-- Material Card Styling -->
        <item name="materialCardViewStyle">@style/Widget.App.CardView</item>
    </style>

    <!-- Custom Card Style -->
    <style name="Widget.App.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">@dimen/card_radius</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="contentPadding">@dimen/card_padding</item>
    </style>

    <!-- Streak Screen Specific Theme -->
    <style name="Theme.ReliableAlarm.StreakHistory" parent="Theme.ReliableAlarm">
        <item name="android:windowBackground">@color/background_main</item>
        <item name="actionBarStyle">@style/Widget.App.ActionBar</item>
    </style>

    <!-- Custom ActionBar -->
    <style name="Widget.App.ActionBar" parent="Widget.MaterialComponents.ActionBar.Solid">
        <item name="elevation">0dp</item>
        <item name="background">@android:color/transparent</item>
    </style>

    <!-- Text Styles -->
    <style name="TextAppearance.App.Headline1" parent="TextAppearance.MaterialComponents.Headline1">
        <item name="android:textSize">@dimen/text_display</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.App.Headline2" parent="TextAppearance.MaterialComponents.Headline2">
        <item name="android:textSize">@dimen/text_headline</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.App.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.App.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.App.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textColor">@color/text_tertiary</item>
    </style>
</resources>