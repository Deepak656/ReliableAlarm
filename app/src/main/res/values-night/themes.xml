<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ══ BASE APPLICATION THEME ════════════════════════════
         NoActionBar — we use Toolbar manually on each screen
         so we control title, back button, elevation per screen. -->
    <style name="Theme.ReliableAlarm" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Brand colors — orange replaces Material purple -->
        <item name="colorPrimary">@color/accent_orange</item>
        <item name="colorPrimaryVariant">@color/accent_orange_dark</item>
        <item name="colorOnPrimary">@color/text_inverse</item>
        <item name="colorSecondary">@color/success_green</item>
        <item name="colorSecondaryVariant">@color/success_green</item>
        <item name="colorOnSecondary">@color/text_inverse</item>
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/background_main</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorError">@color/danger_red</item>
        <item name="colorOnError">@color/text_inverse</item>

        <!-- Status bar — light icons on warm background -->
        <item name="android:statusBarColor" tools:targetApi="l">@color/background_main</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:navigationBarColor">@color/background_main</item>
        <item name="android:windowBackground">@color/background_main</item>

        <!-- Ripple uses orange tint instead of Material default -->
        <item name="colorControlHighlight">@color/accent_orange_light</item>
        <item name="colorControlActivated">@color/accent_orange</item>

        <!-- Component overrides -->
        <item name="materialCardViewStyle">@style/Widget.App.CardView</item>
        <item name="chipStyle">@style/Widget.App.Chip</item>
        <item name="textInputStyle">@style/Widget.App.TextInput</item>
        <item name="materialButtonStyle">@style/Widget.App.Button</item>
        <item name="bottomNavigationStyle">@style/Widget.App.BottomNav</item>

    </style>

    <!-- ══ CARD ══════════════════════════════════════════════
         Flat cards — elevation 0, hairline stroke, warm bg.
         Shadow-based depth is outdated in 2025.            -->
    <style name="Widget.App.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/card_stroke</item>
        <!-- No contentPadding here — each card sets its own padding -->
    </style>

    <!-- ══ CHIP ══════════════════════════════════════════════
         Used for alarm selector on streak screen.          -->
    <style name="Widget.App.Chip" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="chipCornerRadius">20dp</item>
        <item name="chipBackgroundColor">@color/surface_elevated</item>
        <item name="checkedIconVisible">false</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="chipMinHeight">36dp</item>
    </style>

    <!-- ══ TEXT INPUT ════════════════════════════════════════
         Outlined box, orange focus, no shadow.             -->
    <style name="Widget.App.TextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/accent_orange</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">@color/accent_orange</item>
        <item name="android:textColorHint">@color/text_tertiary</item>
    </style>

    <!-- ══ BUTTON ════════════════════════════════════════════
         Full-width, 56dp, orange, no elevation.           -->
    <style name="Widget.App.Button" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">16dp</item>
        <item name="backgroundTint">@color/accent_orange</item>
        <item name="android:textColor">@color/text_inverse</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator" tools:targetApi="lollipop">@null</item>        <item name="rippleColor">@color/accent_orange_dark</item>
    </style>

    <!-- ══ BOTTOM NAVIGATION ═════════════════════════════════
         Matches warm background, orange active indicator.  -->
    <style name="Widget.App.BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="backgroundTint">@color/surface_card</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.App.BottomNav.ActiveIndicator</item>
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="Widget.App.BottomNav.ActiveIndicator"
        parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/accent_orange_light</item>
        <item name="shapeAppearance">@style/ShapeAppearance.App.BottomNav.ActiveIndicator</item>
    </style>

    <style name="ShapeAppearance.App.BottomNav.ActiveIndicator"
        parent="ShapeAppearance.Material3.Corner.Full">
    </style>

    <!-- ══ TEXT APPEARANCES ══════════════════════════════════ -->

    <style name="TextAppearance.App.Display" parent="TextAppearance.MaterialComponents.Headline1">
        <item name="android:textSize">72sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textColor">@color/accent_orange</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="TextAppearance.App.Title" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.App.Headline" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.App.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:lineSpacingMultiplier">1.3</item>
    </style>

    <style name="TextAppearance.App.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_tertiary</item>
    </style>

    <style name="TextAppearance.App.SectionLabel" parent="TextAppearance.MaterialComponents.Overline">
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:letterSpacing">0.12</item>
    </style>

</resources>