<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="20dp"
    android:orientation="vertical">

    <TextView
        android:id="@+id/typingTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Typing Challenge"
        android:textStyle="bold"
        android:textSize="22sp"/>

    <TextView
        android:id="@+id/typingInstructions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Type the below sentence correctly"
        android:textSize="16sp"
        android:layout_marginTop="4dp"
        android:textColor="#666"/>

    <TextView
        android:id="@+id/typingSentence"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Loading..."
        android:textSize="18sp"
        android:layout_marginTop="14dp"
        android:textStyle="bold"/>

    <EditText
        android:id="@+id/typingInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:hint="Start typing here..."
        android:textSize="16sp"
        android:background="@android:drawable/edit_text"/>

    <TextView
        android:id="@+id/typingFeedback"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#E91E63"
        android:textSize="14sp"
        android:layout_marginTop="8dp"/>

</LinearLayout>
