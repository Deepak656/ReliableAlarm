<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pop The Balloons"
            android:textStyle="bold"
            android:textSize="22sp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pop balloons before they fly away!"
            android:textColor="#666"
            android:layout_marginBottom="18dp" />

        <!-- ROUNDS -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rounds"
            android:textStyle="bold"
            android:textSize="18sp"/>

        <TextView
            android:id="@+id/popRoundsValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3 rounds"
            android:textStyle="bold"
            android:textColor="#2196F3"
            android:layout_marginBottom="8dp"/>

        <SeekBar
            android:id="@+id/popRoundsSeek"
            android:max="10"
            android:progress="3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"/>

        <!-- BALLOONS PER ROUND -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Balloons Per Round"
            android:textStyle="bold"
            android:textSize="18sp"/>

        <TextView
            android:id="@+id/popCountValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="8 balloons"
            android:textStyle="bold"
            android:textColor="#2196F3"
            android:layout_marginBottom="8dp"/>

        <SeekBar
            android:id="@+id/popCountSeek"
            android:max="20"
            android:progress="8"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="30dp"/>

        <Button
            android:id="@+id/previewButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Preview Game"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/saveButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Save"/>

    </LinearLayout>
</ScrollView>
