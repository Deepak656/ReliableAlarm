<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="24dp">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="20dp"
        android:background="#DDDDDD"
        android:backgroundTint="#CCCCCC"/>

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add Wake Task"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="16dp"/>

    <!-- Task: Math -->
    <LinearLayout
        android:id="@+id/taskMath"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:background="?attr/selectableItemBackground">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_math"
            android:layout_marginEnd="20dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Math Challenge"
                android:textSize="15sp"
                android:textColor="#1A1A1A"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Solve equations to dismiss"
                android:textSize="12sp"
                android:textColor="#888888"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Task: Walk -->
    <LinearLayout
        android:id="@+id/taskWalk"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:background="?attr/selectableItemBackground">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_walk"
            android:layout_marginEnd="20dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Walking Challenge"
                android:textSize="15sp"
                android:textColor="#1A1A1A"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Count steps to dismiss"
                android:textSize="12sp"
                android:textColor="#888888"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Task: Shake -->
    <LinearLayout
        android:id="@+id/taskShake"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:background="?attr/selectableItemBackground">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_shake"
            android:layout_marginEnd="20dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Shake Challenge"
                android:textSize="15sp"
                android:textColor="#1A1A1A"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Shake your phone to dismiss"
                android:textSize="12sp"
                android:textColor="#888888"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Task: Scan QR -->
    <LinearLayout
        android:id="@+id/taskScanQr"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:background="?attr/selectableItemBackground">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_qr"
            android:layout_marginEnd="20dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scan QR Code"
                android:textSize="15sp"
                android:textColor="#1A1A1A"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scan a barcode to dismiss"
                android:textSize="12sp"
                android:textColor="#888888"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Task: Typing -->
    <LinearLayout
        android:id="@+id/taskTyping"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:background="?attr/selectableItemBackground">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_typing"
            android:layout_marginEnd="20dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Typing Challenge"
                android:textSize="15sp"
                android:textColor="#1A1A1A"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Type a paragraph to dismiss"
                android:textSize="12sp"
                android:textColor="#888888"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Task: Tap -->
    <LinearLayout
        android:id="@+id/taskTap"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:background="?attr/selectableItemBackground">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_tap"
            android:layout_marginEnd="20dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap Challenge"
                android:textSize="15sp"
                android:textColor="#1A1A1A"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap the screen to dismiss"
                android:textSize="12sp"
                android:textColor="#888888"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Task: Color Balls -->
    <LinearLayout
        android:id="@+id/taskColorBalls"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:background="?attr/selectableItemBackground">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_game"
            android:layout_marginEnd="20dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Color Balls"
                android:textSize="15sp"
                android:textColor="#1A1A1A"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sort colored balls to dismiss"
                android:textSize="12sp"
                android:textColor="#888888"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>