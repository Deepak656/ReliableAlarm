<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Math Task -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Math Challenge"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <Switch
            android:id="@+id/mathEnabledSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enable math problems"
            android:layout_marginTop="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Number of problems"
            android:layout_marginTop="16dp"/>

        <SeekBar
            android:id="@+id/mathCountSeek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="9"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/mathCountText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3 problems"
            android:layout_gravity="center"/>
        <Button
            android:id="@+id/mathPreviewBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Preview Math Task"
            android:layout_marginTop="8dp"/>

        <!-- Step Task -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Walking Challenge"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="32dp"/>

        <Switch
            android:id="@+id/stepEnabledSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enable step counter"
            android:layout_marginTop="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Required steps"
            android:layout_marginTop="16dp"/>

        <SeekBar
            android:id="@+id/stepCountSeek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="19"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/stepCountText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="20 steps"
            android:layout_gravity="center"/>
        <Button
            android:id="@+id/stepPreviewBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Preview Step Task"
            android:layout_marginTop="8dp"/>

        <!-- Shake Task -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Shake Challenge"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="32dp"/>

        <Switch
            android:id="@+id/shakeEnabledSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enable shake detection"
            android:layout_marginTop="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Duration (seconds)"
            android:layout_marginTop="16dp"/>

        <SeekBar
            android:id="@+id/shakeDurationSeek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="11"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/shakeDurationText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10 seconds"
            android:layout_gravity="center"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Intensity"
            android:layout_marginTop="16dp"/>

        <SeekBar
            android:id="@+id/shakeIntensitySeek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="9"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/shakeIntensityText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Level 5"
            android:layout_gravity="center"
            android:layout_marginBottom="32dp"/>
        <Button
            android:id="@+id/shakePreviewBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Preview Shake Task"
            android:layout_marginTop="8dp"/>
        <!-- ================= QR / BARCODE TASK ================= -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="QR / Barcode Challenge"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="32dp"/>

        <Switch
            android:id="@+id/qrEnabledSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enable QR scan task"
            android:layout_marginTop="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Number of codes"
            android:layout_marginTop="16dp"/>

        <SeekBar
            android:id="@+id/qrCountSeek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="4"/>

        <TextView
            android:id="@+id/qrCountText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1 code"
            android:layout_gravity="center"/>

        <Button
            android:id="@+id/qrPreviewBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Preview QR Task"
            android:layout_marginTop="8dp"/>


        <!-- ================= TYPING TASK ================= -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Typing Challenge"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="32dp"/>

        <Switch
            android:id="@+id/typingEnabledSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enable typing task"
            android:layout_marginTop="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Paragraphs"
            android:layout_marginTop="16dp"/>

        <SeekBar
            android:id="@+id/typingParagraphSeek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="4"/>

        <TextView
            android:id="@+id/typingParagraphText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1 paragraph"
            android:layout_gravity="center"/>

        <Button
            android:id="@+id/typingPreviewBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Preview Typing Task"
            android:layout_marginTop="8dp"/>


        <!-- ================= TAP TASK ================= -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap Challenge"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="32dp"/>

        <Switch
            android:id="@+id/tapEnabledSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enable tap task"
            android:layout_marginTop="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Required taps"
            android:layout_marginTop="16dp"/>

        <SeekBar
            android:id="@+id/tapCountSeek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="95"/>

        <TextView
            android:id="@+id/tapCountText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="50 taps"
            android:layout_gravity="center"/>

        <Button
            android:id="@+id/tapPreviewBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Preview Tap Task"
            android:layout_marginTop="8dp"/>


        <!-- ================= COLOR BALLS TASK ================= -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Color Balls Challenge"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="32dp"/>

        <Switch
            android:id="@+id/colorBallsEnabledSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enable color balls game"
            android:layout_marginTop="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rounds"
            android:layout_marginTop="16dp"/>

        <SeekBar
            android:id="@+id/colorBallsRoundsSeek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="9"/>

        <TextView
            android:id="@+id/colorBallsRoundsText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3 rounds"
            android:layout_gravity="center"/>

        <Button
            android:id="@+id/colorBallsPreviewBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Preview Color Balls Task"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="32dp"/>

    </LinearLayout>
</ScrollView>