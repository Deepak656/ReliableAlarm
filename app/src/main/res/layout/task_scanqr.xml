<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@android:color/white">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="QR Code Scan Challenge"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:layout_marginBottom="8dp"/>

    <!-- Instructions -->
    <TextView
        android:id="@+id/qrInstructions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Scan any QR codes (product barcodes, books, posters, etc.)"
        android:textSize="16sp"
        android:textColor="#666666"
        android:layout_marginBottom="16dp"/>

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/qrProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="1"
        android:progress="0"
        android:layout_marginBottom="8dp"/>

    <!-- Progress Text -->
    <TextView
        android:id="@+id/qrProgressText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0 / 1 scanned"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp"/>

    <!-- CAMERA PREVIEW -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:layout_marginTop="8dp">

        <androidx.camera.view.PreviewView
            android:id="@+id/qrCameraPreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Feedback -->
    <TextView
        android:id="@+id/qrFeedback"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Align QR / Barcode in the box"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="8dp"/>

    <!-- Help Text -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="💡 Tip: Look for barcodes on bathroom products, cereal boxes, books, or any household items"
        android:textSize="12sp"
        android:textColor="#999999"
        android:textStyle="italic"
        android:layout_marginTop="8dp"
        android:padding="8dp"
        android:background="#F5F5F5"
        android:layout_gravity="center"/>

</LinearLayout>
