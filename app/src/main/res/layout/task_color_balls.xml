<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/colorTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Memory Color Balls"
        android:textStyle="bold"
        android:textSize="24sp"
        android:textColor="@android:color/black"/>

    <TextView
        android:id="@+id/colorInstructions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Memorize the pattern and repeat it"
        android:textSize="15sp"
        android:layout_marginTop="6dp"
        android:textColor="#777"/>

    <ProgressBar
        android:id="@+id/colorProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="5"
        android:layout_marginTop="14dp"/>

    <TextView
        android:id="@+id/colorRoundText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Round 1"
        android:textStyle="bold"
        android:textSize="17sp"
        android:layout_marginTop="10dp"/>

    <!-- GAME CARD -->
    <LinearLayout
        android:id="@+id/gameCard"
        android:layout_width="330dp"
        android:layout_height="330dp"
        android:layout_marginTop="14dp"
        android:padding="12dp"
        android:elevation="6dp"
        android:background="@drawable/game_card_bg">

        <GridLayout
            android:id="@+id/colorGrid"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:rowCount="6"
            android:columnCount="6"
            android:alignmentMode="alignBounds"
            android:useDefaultMargins="true"/>

    </LinearLayout>

    <TextView
        android:id="@+id/colorFeedback"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="17sp"
        android:layout_marginTop="16dp"
        android:textAlignment="center"
        android:textColor="@android:color/black"/>

</LinearLayout>
