<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="20dp"
    android:orientation="vertical">

    <TextView
        android:id="@+id/tapTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap Challenge"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"/>

    <TextView
        android:id="@+id/tapInstructions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap button repeatedly to dismiss alarm"
        android:textSize="16sp"
        android:layout_marginTop="6dp"
        android:textColor="#666"/>

    <ProgressBar
        android:id="@+id/tapProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="30"
        android:progress="0"
        android:layout_marginTop="12dp"/>

    <TextView
        android:id="@+id/tapProgressText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0 / 30 taps"
        android:textStyle="bold"
        android:textSize="16sp"
        android:layout_marginTop="8dp"/>

    <Button
        android:id="@+id/tapButton"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:text="TAP!"
        android:textStyle="bold"
        android:textSize="22sp"
        android:layout_marginTop="20dp"/>
</LinearLayout>
